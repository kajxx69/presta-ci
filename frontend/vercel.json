{
  "rewrites": [
    { "source": "/assets/(.*)", "destination": "/assets/$1" },
    { "source": "/(.*)\\.js", "destination": "/$1.js" },
    { "source": "/(.*)\\.css", "destination": "/$1.css" },
    { "source": "/(.*)\\.wasm", "destination": "/$1.wasm" },
    { "source": "/(.*)\\.svg", "destination": "/$1.svg" },
    { "source": "/(.*)\\.png", "destination": "/$1.png" },
    { "source": "/(.*)\\.ico", "destination": "/$1.ico" },
    { "source": "/(.*)\\.webp", "destination": "/$1.webp" },
    { "source": "/(.*)\\.json", "destination": "/$1.json" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/(.*)\\.js",
      "headers": [
        { "key": "Content-Type", "value": "application/javascript; charset=utf-8" },
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/(.*)\\.css",
      "headers": [
        { "key": "Content-Type", "value": "text/css; charset=utf-8" },
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
