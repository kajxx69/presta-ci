PORT=4000

# Origines frontend autorisées (séparées par des virgules)
FRONTEND_ORIGIN=http://localhost:5173

# JWT — IMPORTANT: utiliser une clé forte et unique en production (min 64 caractères)
JWT_SECRET=CHANGE_ME_USE_A_STRONG_RANDOM_SECRET
JWT_EXPIRES_IN=7d

# MongoDB Atlas
MONGODB_URI=mongodb+srv://USERNAME:PASSWORD@cluster.mongodb.net/prestation?retryWrites=true&w=majority
