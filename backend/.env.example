PORT=4000

# Origines frontend autorisées (séparées par des virgules)
FRONTEND_ORIGIN=http://localhost:5173

# JWT — IMPORTANT: utiliser une clé forte et unique en production (min 64 caractères)
JWT_SECRET=CHANGE_ME_USE_A_STRONG_RANDOM_SECRET
JWT_EXPIRES_IN=7d

# MongoDB Atlas
MONGODB_URI=mongodb+srv://USERNAME:PASSWORD@cluster.mongodb.net/prestation?retryWrites=true&w=majority

# Resend (envoi d'emails: réinitialisation de mot de passe, notifications)
# Clé API sur https://resend.com/api-keys — si absente, les emails ne sont pas
# envoyés et les liens apparaissent dans les logs serveur
RESEND_API_KEY=
# L'adresse doit appartenir à un domaine vérifié dans Resend (Domains → Add Domain)
MAIL_FROM=PrestaCI <no-reply@prestaci.com>

# Base publique du backend (URLs des fichiers uploadés). Ex: https://api.prestaci.com
PUBLIC_BASE_URL=http://localhost:4000
